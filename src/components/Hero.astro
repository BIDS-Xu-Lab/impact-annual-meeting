---
import { Image } from "astro:assets";
import Button from "./Button.astro";
import brainMark from "../assets/impact-brain.png";
import { event } from "../data/agenda";
---

<section id="top" class="hero surface-dark">
  <Image class="hero-mark" src={brainMark} alt="" aria-hidden="true" width={512} height={512} />

  <div class="container hero-inner">
    <p class="hero-tag stagger" style="--i: 0">
      <span class="hero-tag-dot" aria-hidden="true"></span>
      In-Person Annual Meeting
    </p>

    <h1 class="hero-title stagger" style="--i: 1">
      IMPACT-MH 2026
      <span class="hero-title-accent">Annual Meeting</span>
    </h1>

    <div class="hero-meta stagger" style="--i: 2">
      <div class="hero-meta-item">
        <span class="hero-meta-label">Date</span>
        <span class="hero-meta-value">September 22nd – 23rd</span>
      </div>
      <div class="hero-meta-divider" aria-hidden="true"></div>
      <div class="hero-meta-item">
        <span class="hero-meta-label">Location</span>
        <span class="hero-meta-value">NIH, 6001 Executive Blvd, Rockville, MD 20852</span>
      </div>
    </div>

    <div class="hero-actions stagger" style="--i: 3">
      <Button href={event.registerUrl} size="lg" newTab>Register Now</Button>
      <Button href="#agenda" variant="ghost" size="lg">View Agenda</Button>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 95svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-block: calc(var(--header-height) + 2rem) 3rem;
  }

  .hero-mark {
    position: absolute;
    right: -8%;
    top: 50%;
    width: min(640px, 60vw);
    transform: translateY(-50%);
    opacity: 0.1;
    filter: blur(2px) saturate(0.9);
    pointer-events: none;
    user-select: none;
  }

  .hero-inner {
    position: relative;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 1.1rem;
    border: 1px solid var(--border-dark);
    border-radius: var(--radius-pill);
    background: rgba(202, 227, 255, 0.07);
    backdrop-filter: blur(8px);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--blue-pale);
  }

  .hero-tag-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--mint);
    box-shadow: 0 0 0 0 rgba(168, 230, 207, 0.6);
    animation: pulse 2.4s ease-out infinite;
  }

  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(168, 230, 207, 0.6);
    }
    70% {
      box-shadow: 0 0 0 10px rgba(168, 230, 207, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(168, 230, 207, 0);
    }
  }

  .hero-title {
    margin-top: 1rem;
    max-width: 16ch;
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: 600;
    color: #ffffff;
    letter-spacing: -0.01em;
  }

  .hero-title-accent {
    display: block;
    font-style: italic;
    background: linear-gradient(100deg, #ffffff 10%, var(--blue) 90%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .hero-meta {
    display: inline-flex;
    align-items: center;
    gap: 1.75rem;
    margin-top: 1.5rem;
    padding: 1.1rem 1.75rem;
    border: 1px solid var(--border-dark);
    border-radius: var(--radius-card);
    background: rgba(0, 53, 107, 0.25);
    backdrop-filter: blur(12px);
  }

  .hero-meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .hero-meta-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--blue);
  }

  .hero-meta-value {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    color: #ffffff;
  }

  .hero-meta-divider {
    width: 1px;
    align-self: stretch;
    background: var(--border-dark);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  /* staggered entrance */
  .stagger {
    opacity: 0;
    animation: rise 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(var(--i) * 110ms + 100ms);
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(26px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .stagger {
      opacity: 1;
      animation: none;
    }
  }

  @media (max-width: 768px) {
    .hero-mark {
      right: -35%;
      width: 110vw;
      opacity: 0.07;
    }

    .hero-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      width: 100%;
    }

    .hero-meta-divider {
      width: 100%;
      height: 1px;
      align-self: auto;
    }
  }
</style>
