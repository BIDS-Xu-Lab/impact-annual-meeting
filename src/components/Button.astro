---
interface Props {
  href: string;
  variant?: "pink" | "ghost";
  size?: "md" | "lg";
  newTab?: boolean;
}

const { href, variant = "pink", size = "md", newTab = false } = Astro.props;
---

<a
  href={href}
  class:list={["btn", `btn-${variant}`, size === "lg" && "btn-lg"]}
  target={newTab ? "_blank" : undefined}
  rel={newTab ? "noopener noreferrer" : undefined}
>
  <slot />
</a>
